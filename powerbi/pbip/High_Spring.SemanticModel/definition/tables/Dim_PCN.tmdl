						"Data_Lab_SWL_Live",
						[
							Query = "SELECT [SK_PCNID] AS [PCNKey], [PCN_Code] AS [PCN Code], [PCN_Name] AS [PCN], [ICB_Code] AS [ICB Code], [ICB_Name] AS [ICB], [Town], [Postcode], [Is_Active] AS [Is Active], [Is_Current] AS [Is Current] FROM [Analytics].[tbl_Dim_PCN] WHERE [Is_Current] = 1 OR [SK_PCNID] = -1"
