riance], [Service_Category_Variance] AS [Service Category Variance], [Is_Operating_Plan] AS [Is Operating Plan], [Is_ERF_Eligible] AS [Is ERF Eligible] FROM [Analytics].[tbl_Fact_IP_Activity]"])
