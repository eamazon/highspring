createOrReplace

	table Dim_Date

		column DateKey
			dataType: int64
			isKey
			summarizeBy: none
			sourceColumn: DateKey

		column Date
			dataType: dateTime
			formatString: dd/MM/yyyy
			summarizeBy: none
			sourceColumn: Date

		column 'Day of Month'
			dataType: int64
			summarizeBy: none
			sourceColumn: Day of Month

		column 'Day Name'
			dataType: string
			summarizeBy: none
			sourceColumn: Day Name
			sortByColumn: 'Day of Week'

		column 'Day of Week'
			dataType: int64
			summarizeBy: none
			sourceColumn: Day of Week

		column 'Week Number'
			dataType: int64
			summarizeBy: none
			sourceColumn: Week Number

		column 'Month Number'
			dataType: int64
			summarizeBy: none
			sourceColumn: Month Number

		column 'Month Name'
			dataType: string
			summarizeBy: none
			sourceColumn: Month Name
			sortByColumn: 'Financial Month'

		column Month
			dataType: string
			summarizeBy: none
			sourceColumn: Month
			sortByColumn: 'Financial Month'

		column 'Calendar Quarter'
			dataType: int64
			summarizeBy: none
			sourceColumn: Calendar Quarter

		column 'Calendar Year'
			dataType: int64
			summarizeBy: none
			sourceColumn: Calendar Year

		column 'Financial Month'
			dataType: int64
			summarizeBy: none
			sourceColumn: Financial Month

		column 'Financial Quarter'
			dataType: int64
			summarizeBy: none
			sourceColumn: Financial Quarter

		column 'Financial Year Number'
			dataType: int64
			summarizeBy: none
			sourceColumn: Financial Year Number

		column 'Financial Year'
			dataType: string
			summarizeBy: none
			sourceColumn: Financial Year
			sortByColumn: 'Financial Year Number'

		column 'FY Short'
			dataType: string
			summarizeBy: none
			sourceColumn: FY Short
			sortByColumn: 'Financial Year Number'

		column 'Is Weekend'
			dataType: boolean
			summarizeBy: none
			sourceColumn: Is Weekend

		column 'Is Bank Holiday'
			dataType: boolean
			summarizeBy: none
			sourceColumn: Is Bank Holiday

		column 'Bank Holiday'
			dataType: string
			summarizeBy: none
			sourceColumn: Bank Holiday

		column 'Is School Holiday'
			dataType: boolean
			summarizeBy: none
			sourceColumn: Is School Holiday

		column 'Is NHS Strike Day'
			dataType: boolean
			summarizeBy: none
			sourceColumn: Is NHS Strike Day

		column 'Is Christmas Period'
			dataType: boolean
			summarizeBy: none
			sourceColumn: Is Christmas Period

		column 'Is Easter Period'
			dataType: boolean
			summarizeBy: none
			sourceColumn: Is Easter Period

		partition Dim_Date = m
			mode: import
			source =
				let
				    Source = Sql.Database("PSFADHSSTP02.ad.elc.nhs.uk\SWL", "Data_Lab_SWL_Live", [Query="SELECT [SK_Date] AS [DateKey], [FullDate] AS [Date], [Day] AS [Day of Month], [DayOfWeek] AS [Day Name], [DayOfWeekNumber] AS [Day of Week], [WeekOfYearNumber] AS [Week Number], [CalendarMonthNumber] AS [Month Number], [CalendarMonthName] AS [Month Name], [CalendarMonthNameShort] AS [Month], [CalendarQuarterNumber] AS [Calendar Quarter], [CalendarYearNumber] AS [Calendar Year], [FiscalCalendarMonthNumber] AS [Financial Month], [FiscalCalendarQuarterNumber] AS [Financial Quarter], [FiscalCalendarYearNumber] AS [Financial Year Number], [FiscalCalendarYearName] AS [Financial Year], [FiscalCalendarYearNameShort] AS [FY Short], [IsWeekend] AS [Is Weekend], [IsBankHoliday] AS [Is Bank Holiday], [BankHoliday_Name] AS [Bank Holiday], [IsSchoolHoliday] AS [Is School Holiday], [IsNHSStrikeDay] AS [Is NHS Strike Day], [IsChristmasPeriod] AS [Is Christmas Period], [IsEasterPeriod] AS [Is Easter Period] FROM [Analytics].[vw_Dim_Date] WHERE [FullDate] >= '2019-04-01' AND [FullDate] <= DATEADD(YEAR, 1, GETDATE())"])
				in
				    Source

		hierarchy 'Calendar Hierarchy'
			level 'Calendar Year'
				column: 'Calendar Year'
			level 'Calendar Quarter'
				column: 'Calendar Quarter'
			level 'Month Name'
				column: 'Month Name'
			level Date
				column: Date

		hierarchy 'Financial Year Hierarchy'
			level 'Financial Year'
				column: 'Financial Year'
			level 'Financial Quarter'
				column: 'Financial Quarter'
			level 'Financial Month'
				column: 'Financial Month'
			level Date
				column: Date

		hierarchy 'Week Hierarchy'
			level 'Calendar Year'
				column: 'Calendar Year'
			level 'Week Number'
				column: 'Week Number'
			level 'Day Name'
				column: 'Day Name'

	table Dim_Commissioner

